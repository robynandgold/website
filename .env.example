# Copy this file to .env for local development (DO NOT COMMIT .env)
# For production, set these in Vercel Dashboard: Settings > Environment Variables

# Stripe Secret Key (starts with sk_test_ or sk_live_)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Currency for payments (ISO 4217 code)
STRIPE_CURRENCY=eur

# Your site URL (no trailing slash)
# Local: http://localhost:3000
# Production: https://yourdomain.com
SITE_URL=http://localhost:3000

# GitHub token with write access to this repo (used by the webhook to mark
# items sold, and by the admin page to publish/edit products). Already set if
# the sell-out webhook works.
GITHUB_TOKEN=ghp_or_github_pat_your_token_here

# Password for the admin product page (/pages/add-product.html). The page
# sends this to /api/admin-token; on a match the server returns GITHUB_TOKEN.
# Choose a strong value — anyone with it can add/edit/delete products.
ADMIN_PASSWORD=choose_a_strong_password
