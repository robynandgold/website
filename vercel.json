{
  "buildCommand": "npm run build",
  "outputDirectory": "src",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.robynandgold.com" }],
      "destination": "https://robynandgold.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/", "destination": "/src/index.html" },
    { "source": "/(.*)", "destination": "/src/$1" }
  ]
}
